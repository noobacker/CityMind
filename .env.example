# ==============================================================================
# CITYMIND // NEURAL_GRID_ENVIRONMENT_CONFIGURATION
# ==============================================================================
# Copy this file to .env.local and populate the keys to enable the full 
# neural city experience.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. GEOSPATIAL_GRID (MAPBOX)
# ------------------------------------------------------------------------------
# Required for rendering the high-fidelity tactical city map.
# Get your token at: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here

# ------------------------------------------------------------------------------
# 2. ATMOSPHERIC_SENSORS (WEATHER & AQI)
# ------------------------------------------------------------------------------
# Required for real-time air quality and weather telemetry.
# Get your key at: https://home.openweathermap.org/api_keys
OPENWEATHER_KEY=your_openweather_api_key_here

# ------------------------------------------------------------------------------
# 3. NEURAL_ENGINE (GROQ / LLM)
# ------------------------------------------------------------------------------
# Primary engine for the city's personality and tactical analysis.
# Get your token at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Reserved for future neural speech integration.
GROQ_SPEECH_API_KEY=your_groq_speech_api_key_here
GROQ_SPEECH_MODEL=canopylabs/orpheus-v1-english

# Optional: Primary Anthropic engine (if preferred over Groq).
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------------------------
# 4. NEURAL_VOICE_SYNTHESIS (TTS)
# ------------------------------------------------------------------------------
# Required for the default neural voice (Hugging Face).
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Optional: Premium high-fidelity voice synthesis.
# Get your key at: https://elevenlabs.io/api
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here